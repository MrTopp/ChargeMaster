@page "/electricity-prices"
@using ChargeMaster.Data
@using ChargeMaster.Services.ElectricityPrice
@using System.Globalization
@inject ElectricityPriceService PriceService
@inject IJSRuntime Js
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>Elpriser - Charge Master</PageTitle>

<div class="container-md mb-3 px-2 px-sm-3 px-md-4" style="min-height: 100vh; display: flex; flex-direction: column;">
    <div style="flex: 0.5 1 0; max-height: 3rem; min-height: 8px;"></div>

    <section class="mb-3">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-3">Elpriser</h4>
            
            <div class="mb-3 d-flex align-items-center gap-2 flex-wrap">
                <button class="btn btn-secondary btn-sm" 
                        @onclick="PreviousDayAsync" 
                        disabled="@(_isCheckingPrevious || !_hasPreviousDayPrices)">
                    ← Föregående dag
                </button>
                <label for="price-date" class="form-label mb-0">Välj datum:</label>
                <InputDate id="price-date" @bind-Value="_selectedDate" @bind-Value:after="LoadPricesAsync" class="form-control w-auto" min="2025-10-01" max="@_maxSelectableDate.ToString("yyyy-MM-dd")" />
                <button class="btn btn-secondary btn-sm" 
                        @onclick="NextDayAsync" 
                        disabled="@(_isCheckingNext || !_hasNextDayPrices)">
                    Nästa dag →
                </button>
            </div>
            
            @if (_prices is { Count: > 0 })
            {
                <div style="max-height: 300px; margin-bottom: 2rem;">
                    <canvas id="priceChart"></canvas>
                </div>
            }
        </div>
    </section>

    <section class="mb-3">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            @if (_prices == null)
            {
                <p><em>Laddar priser...</em></p>
            }
            else if (_prices.Count == 0)
            {
                <div class="alert alert-info">
                    Inga priser hittades för @_selectedDate.ToString("yyyy-MM-dd").
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-sm">
                        <thead>
                            <tr>
                                <th>Timme</th>
                                <th class="text-end">KV1</th>
                                <th class="text-end">KV2</th>
                                <th class="text-end">KV3</th>
                                <th class="text-end">KV4</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var groupedByHour = _prices.GroupBy(p => p.TimeStart.Hour).OrderBy(g => g.Key);
                                foreach (var hourGroup in groupedByHour)
                                {
                                    var hour = hourGroup.Key;
                                    var pricesInHour = hourGroup.OrderBy(p => p.TimeStart).ToList();
                                    <tr>
                                        <td>@hour.ToString("00"):00</td>
                                        @for (int quarter = 0; quarter < 4; quarter++)
                                        {
                                            var price = pricesInHour.FirstOrDefault(p => p.TimeStart.Minute == quarter * 15);
                                            var isCurrentQuarter = IsCurrentQuarter(hour, quarter);
                                            <td class="text-end" style="@(isCurrentQuarter ? "background-color: rgba(13, 110, 253, 0.1); font-weight: 500;" : "")">
                                                @if (price != null)
                                                {
                                                    @price.SekPerKwh.ToString("F2", CultureInfo.GetCultureInfo("sv-SE"))
                                                }
                                                else
                                                {
                                                    @:—
                                                }
                                            </td>
                                        }
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>

    <section>
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <p class="mb-0 d-flex gap-2">
                <a href="index" class="btn btn-secondary btn-sm">Översikt</a>
                <a href="energy-usage" class="btn btn-secondary btn-sm">Timförbrukning</a>
                <a href="monthly-costs" class="btn btn-secondary btn-sm">Nätavgifter</a>
            </p>
            <p/>
            <p>
                <a href="https://www.elprisetjustnu.se">
                    <img src="https://i.bnfcl.io/hva-koster-strommen/elpriser-tillhandahalls-av-elprisetjustnu_ttNExOIU_.png" alt="Elpriser tillhandahålls av Elpriset just nu.se" width="200" height="45">
                </a>
            </p>
        </div>
    </section>
</div>

@code {
    private DateOnly _selectedDate = DateOnly.FromDateTime(DateTime.Now);
    private DateOnly _maxSelectableDate;
    private List<ElectricityPrice>? _prices;
    private IJSObjectReference? _module;
    private bool _hasPreviousDayPrices = true;
    private bool _hasNextDayPrices = true;
    private bool _isCheckingPrevious;
    private bool _isCheckingNext;
    private bool _isDisposed;

    protected override async Task OnInitializedAsync()
    {
        var now = DateTime.Now;
        var today = DateOnly.FromDateTime(now);

        // If time is after 13:10, next day's prices are likely available
        if (now.Hour > 13 || (now.Hour == 13 && now.Minute >= 10))
        {
            _maxSelectableDate = today.AddDays(1);
        }
        else
        {
            _maxSelectableDate = today;
        }

        await LoadPricesAsync();
        await UpdateNavigationAvailabilityAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isDisposed)
            return;

        try
        {
            if (firstRender)
            {
                try
                {
                    _module = await Js.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/ElectricityPrices.razor.js");
                }
                catch (JSDisconnectedException)
                {
                    return;
                }

                // Initialize chart if prices are already loaded
                if (_prices?.Count > 0)
                {
                    await RenderChartAsync();
                }
            }
            else if (_module != null && _prices?.Count > 0)
            {
                // Render chart when prices are updated
                await RenderChartAsync();
            }
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected, ignore
        }
    }

    private async Task LoadPricesAsync()
    {
        _prices = null; // Show loading state briefly
        await InvokeAsync(StateHasChanged);

        _prices = await PriceService.GetPricesForDateAsync(_selectedDate);

        // Trigger re-render which will call OnAfterRenderAsync
        await InvokeAsync(StateHasChanged);

        await UpdateNavigationAvailabilityAsync();
    }

    private async Task UpdateNavigationAvailabilityAsync()
    {
        _isCheckingPrevious = true;
        _isCheckingNext = true;
        await InvokeAsync(StateHasChanged);

        var previousDayPrices = await PriceService.GetPricesForDateAsync(_selectedDate.AddDays(-1));
        var nextDayPrices = await PriceService.GetPricesForDateAsync(_selectedDate.AddDays(1));

        _hasPreviousDayPrices = previousDayPrices?.Count > 0;
        _hasNextDayPrices = nextDayPrices?.Count > 0;
        _isCheckingPrevious = false;
        _isCheckingNext = false;

        await InvokeAsync(StateHasChanged);
    }

    private async Task PreviousDayAsync()
    {
        _selectedDate = _selectedDate.AddDays(-1);
        await LoadPricesAsync();
    }

    private async Task NextDayAsync()
    {
        _selectedDate = _selectedDate.AddDays(1);
        await LoadPricesAsync();
    }

    private async Task RenderChartAsync()
    {
        if (_isDisposed || _module == null || _prices?.Count == 0)
            return;

        var labels = _prices.Select(p => p.TimeStart.ToString("HH:mm")).ToList();
        var data = _prices.Select(p => p.SekPerKwh).ToList();

        var today = DateOnly.FromDateTime(DateTime.Now);
        string? currentTime = null;

        if (_selectedDate == today)
        {
            var now = DateTime.Now;
            var minutes = now.Minute;
            var roundedMinutes = (minutes / 15) * 15;
            var roundedTime = new DateTime(now.Year, now.Month, now.Day, now.Hour, roundedMinutes, 0);
            currentTime = roundedTime.ToString("HH:mm");
        }

        try
        {
            await _module.InvokeVoidAsync("initializeChart", labels, data, currentTime);
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected, ignore
        }
    }

    private bool IsCurrentQuarter(int hour, int quarter)
    {
        var today = DateOnly.FromDateTime(DateTime.Now);
        if (_selectedDate != today)
            return false;

        var now = DateTime.Now;
        var minutes = now.Minute;
        var roundedMinutes = (minutes / 15) * 15;

        return now.Hour == hour && roundedMinutes == quarter * 15;
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        _isDisposed = true;
        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit already disconnected, resources will be cleaned up by the browser
            }
        }
    }
}
