@page "/electricity-prices"
@using ChargeMaster.Data
@using ChargeMaster.Services.ElectricityPrice
@using System.Globalization
@inject ElectricityPriceService PriceService
@inject IJSRuntime JS
@rendermode InteractiveServer
@implements IAsyncDisposable

<PageTitle>Elpriser - Charge Master</PageTitle>

<div class="container-md mb-3 px-2 px-sm-3 px-md-4" style="min-height: 100vh; display: flex; flex-direction: column;">
    <div style="flex: 0.5 1 0; max-height: 3rem; min-height: 8px;"></div>

    <section class="mb-3">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-3">Elpriser</h4>
            
            <div class="mb-3 d-flex align-items-center gap-2">
                <label for="price-date" class="form-label mb-0">Välj datum:</label>
                <InputDate id="price-date" @bind-Value="selectedDate" @bind-Value:after="LoadPricesAsync" class="form-control w-auto" />
            </div>
            
            @if (prices is { Count: > 0 })
            {
                <div style="max-height: 300px; margin-bottom: 2rem;">
                    <canvas id="priceChart"></canvas>
                </div>
            }
        </div>
    </section>

    <section class="mb-3">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            @if (prices == null)
            {
                <p><em>Laddar priser...</em></p>
            }
            else if (prices.Count == 0)
            {
                <div class="alert alert-info">
                    Inga priser hittades för @selectedDate.ToString("yyyy-MM-dd").
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-striped table-hover table-sm">
                        <thead>
                            <tr>
                                <th>Tidsintervall</th>
                                <th class="text-end">SEK / kWh</th>
                                <th class="text-end">EUR / kWh</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var price in prices)
                            {
                                <tr>
                                    <td>@price.TimeStart.ToString("HH:mm") - @price.TimeEnd.ToString("HH:mm")</td>
                                    <td class="text-end">@price.SekPerKwh.ToString("F2", CultureInfo.GetCultureInfo("sv-SE"))</td>
                                    <td class="text-end">@price.EurPerKwh.ToString("F2", CultureInfo.GetCultureInfo("sv-SE"))</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </section>

    <section>
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <p class="mb-0 d-flex gap-2">
                <a href="/" class="btn btn-secondary btn-sm">Tillbaka till hem</a>
                <a href="energy-usage" class="btn btn-secondary btn-sm">Timförbrukning</a>
                <a href="monthly-costs" class="btn btn-secondary btn-sm">Kostnader denna månad</a>
            </p>
        </div>
    </section>
</div>

@code {
    private DateOnly selectedDate = DateOnly.FromDateTime(DateTime.Now);
    private List<ElectricityPrice>? prices;
    private IJSObjectReference? module;

    protected override async Task OnInitializedAsync()
    {
        await LoadPricesAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            module = await JS.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/ElectricityPrices.razor.js");

            // Initialize chart if prices are already loaded
            if (prices?.Count > 0)
            {
                await RenderChartAsync();
            }
        }
        else if (module != null && prices?.Count > 0)
        {
            // Render chart when prices are updated
            await RenderChartAsync();
        }
    }

    private async Task LoadPricesAsync()
    {
        prices = null; // Show loading state briefly
        await InvokeAsync(StateHasChanged);

        prices = await PriceService.GetPricesForDateAsync(selectedDate);

        // Trigger re-render which will call OnAfterRenderAsync
        await InvokeAsync(StateHasChanged);
    }

    private async Task RenderChartAsync()
    {
        if (module == null || prices?.Count == 0)
            return;

        var labels = prices.Select(p => p.TimeStart.ToString("HH:mm")).ToList();
        var data = prices.Select(p => p.SekPerKwh).ToList();
        await module.InvokeVoidAsync("initializeChart", labels, data);
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        if (module is not null)
        {
            await module.DisposeAsync();
        }
    }
}
