@page "/index"
@page "/"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject WallboxWorker WallboxWorker
@inject ChargeWorker ChargeWorker
@inject TibberVehicleService TibberVehicleService
@inject DaikinFacade DaikinFacade
@inject ShellyMqttService ShellyMqttService
@inject SmhiWorker SmhiWorker
@inject LinuxWorker LinuxWorker
@inject ErrorLogService ErrorLogService
@inject ElectricityPriceService ElectricityPriceService
@inject IJSRuntime Js
@inject ILogger<Home> Logger
@using ChargeMaster.Data
@using ChargeMaster.Services.Wallbox
@using ChargeMaster.Services.TibberVehicle
@using ChargeMaster.Services.Daikin
@using ChargeMaster.Services.Shelly
@using ChargeMaster.Services.SMHI
@using ChargeMaster.Services.ErrorLog
@using ChargeMaster.Services.ElectricityPrice
@using ChargeMaster.Workers

<PageTitle>Charge Master</PageTitle>

<div class="container-md mb-3 px-2 px-sm-3 px-md-4" style="min-height: 100vh; display: flex; flex-direction: column;">
    <div style="flex: 0.5 1 0; max-height: 3rem; min-height: 8px;"></div>

    <section class="mb-1">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-2">Aktuell effekt</h4>

            @if (CurrentMeterInfo is not null)
            {
                <div class="row g-2 mb-3">
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                        <small class="text-muted">Fas 1:</small><br>
                        <strong>@CurrentMeterInfo.Phase1CurrentEnergy W</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                        <small class="text-muted">Fas 2:</small><br>
                        <strong>@CurrentMeterInfo.Phase2CurrentEnergy W</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                        <small class="text-muted">Fas 3:</small><br>
                        <strong>@CurrentMeterInfo.Phase3CurrentEnergy W</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                        <small class="text-muted">Total:</small><br>
                        <strong>@CurrentMeterInfo.CurrentEnergy W</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                        <small class="text-muted">Denna timme:</small><br>
                        <strong>@CurrentMeterInfo.EffektTimmeNuFormatted Wh</strong>
                    </div>
                    <div class="col-auto"
                         style="padding: 0.5rem; border-radius: 0.25rem; @(CurrentMeterInfo.EffektTimmeTotal > 2500 ? "background-color: #f8d7da;" : "")">
                        <small class="text-muted">Uppskattad timme:</small><br>
                        <strong>@CurrentMeterInfo.EffektTimmeTotalFormatted Wh</strong>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="mb-3">
        <div class="row g-3" style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <div class="col-md-5">
                <h4 class="mb-2">Temperatur (Shelly)</h4>
                <div class="row g-2">
                    <div class="col-auto"
                         style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedShellyProperties.Contains("sovrum") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Sovrum:</small><br>
                        <strong>@ShellyTemperatures["sovrum"]?.ToString("F1")°</strong>
                    </div>
                    <div class="col-auto"
                         style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedShellyProperties.Contains("hall") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Hall:</small><br>
                        <strong>@ShellyTemperatures["hall"]?.ToString("F1")°</strong>
                    </div>
                    <div class="col-auto"
                         style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedShellyProperties.Contains("arbetsrum") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Arbetsrum:</small><br>
                        <strong>@ShellyTemperatures["arbetsrum"]?.ToString("F1")°</strong>
                    </div>
                </div>
            </div>
            <div class="col-md-7">
                <h4 class="mb-2">Värmepump (Daikin)</h4>
                <div class="row g-2">
                    <div class="col-auto"
                         style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("CurrentTemperature") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Inne:</small><br>
                        <strong>@DaikinFacade.CurrentTemperature?.ToString("F1")°</strong>
                    </div>
                    <div class="col-auto"
                         style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("OutdoorTemperature") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Ute:</small><br>
                        <strong>@DaikinFacade.OutdoorTemperature?.ToString("F1")°</strong>
                    </div>
                    <div class="col-auto"
                         style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("TargetTemperature") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Mål:</small><br>
                        <strong>@DaikinFacade.TargetTemperature?.ToString("F1")°</strong>
                    </div>
                    <div class="col-auto"
                         style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("Mode") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Läge:</small><br>
                        <strong>@(DaikinFacade.IsOn ? DaikinFacade.Mode.ToString() : "Av")</strong>
                    </div>
                    <div class="col-auto"
                         style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("CompressorFrequency") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Kompr.:</small><br>
                        <strong>@(DaikinFacade.CompressorFrequency ?? 0)</strong>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-1">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-0">Elpriser</h4>

            @if (CurrentElectricityPrices is { Count: > 0 })
            {
                <div style="max-height: 300px; min-height: 200px;">
                    <canvas id="priceChartHome"></canvas>
                </div>
            }
            else if (CurrentElectricityPrices != null && CurrentElectricityPrices.Count == 0)
            {
                <p class="text-muted mb-0"><em>Ingen prisdata tillgänglig för närvarande</em></p>
            }
        </div>
    </section>

    <section class="mb-1">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-2">Väderprognos (SMHI)</h4>

            @if (CurrentWeatherForecast.Count > 0)
            {
                var forecasts = CurrentWeatherForecast.Take(14).ToList();
                <div class="row g-2 mb-3 flex-nowrap">
                    @for (var i = 0; i < forecasts.Count; i++)
                    {
                        var responsiveClass = i switch
                        {
                            < 10 => "",
                            < 11 => "d-none d-sm-block",
                            _ => "d-none d-md-block"
                        };
                        <div class="col-auto @responsiveClass"
                             style="padding: 0.5rem; border-radius: 0.25rem; text-align: center;">
                            <small class="text-muted">@forecasts[i].Time.ToString("H:mm")</small><br>
                            <strong>@forecasts[i].Temperature.ToString("F1")°</strong><br>
                            <span
                                style="font-size: 1.5rem; line-height: 1; display: block; margin-top: 0.25rem;">@forecasts[i].WeatherEmoji</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mb-0"><em>Ingen data tillgänglig</em></p>
            }
        </div>
    </section>

    <section class="mb-1">
        <div class="row g-3" style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <div class="col-md-5">
                <h4 class="mb-2">Bilens laddstatus</h4>

                @if (CurrentTibberVehicleStatus is not null)
                {
                    <div class="row g-2">
                        <div class="col-auto">
                            <small class="text-muted">Batterinivå:</small><br>
                            <strong>@((CurrentTibberVehicleStatus.BatteryLevel ?? 0.0).ToString("F0")) %</strong>
                        </div>
                        <div class="col-auto">
                            <small class="text-muted">Målnivå:</small><br>
                            <strong>@((CurrentTibberVehicleStatus.ChargingSettingsTargetLevel ?? 0.0).ToString("F0")) %</strong>
                        </div>
                        <div class="col-auto">
                            <small class="text-muted">Laddeffekt:</small><br>
                            <strong>@((CurrentTibberVehicleStatus.ChargingPower ?? 0.0).ToString("F0")) W</strong>
                        </div>
                        <div class="col-auto">
                            <small class="text-muted">Laddar:</small><br>
                            <strong>@(CurrentTibberVehicleStatus.IsCharging == true ? "Ja" : "Nej")</strong>
                        </div>
                    </div>
                }
            </div>
            @if (SystemLoad is not null)
            {
                <div class="col-md-7">
                    <h4 class="mb-2">Systemlast (Linux)</h4>

                    <div class="row g-2">
                        <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                            <small class="text-muted">1 minut:</small><br>
                            <strong>@SystemLoad.Load1.ToString("F2")</strong>
                        </div>
                        <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                            <small class="text-muted">5 minuter:</small><br>
                            <strong>@SystemLoad.Load5.ToString("F2")</strong>
                        </div>
                        <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                            <small class="text-muted">15 minuter:</small><br>
                            <strong>@SystemLoad.Load15.ToString("F2")</strong>
                        </div>
                        <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                            <small class="text-muted">Processer:</small><br>
                            <strong>@SystemLoad.RunningProcesses/@SystemLoad.TotalProcesses</strong>
                        </div>
                    </div>
                </div>
            }
        </div>
    </section> 

    <section class="mb-1">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-2">Planerad laddning (om behov finns)</h4>

            @if (CurrentKvartlista is not null && CurrentKvartlista.Count > 0)
            {
                <div style="display: grid; grid-template-columns: repeat(8, 1fr); gap: 0.5rem;" class="mb-3">
                    @foreach (var kvart in CurrentKvartlista.OrderBy(x => x.TimeStart))
                    {
                        <div
                            style="padding: 0.5rem; border-radius: 0.25rem; text-align: center; background-color: #f8f9fa;">
                            <small class="text-muted">@kvart.TimeStart.ToString("MM-dd HH:mm")</small><br>
                            <strong>@kvart.SekPerKwh.ToString("F2") kr</strong>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0 p-2" role="alert">
                    Ingen laddning är planerad.
                </div>
            }
        </div>
    </section>

    <section class="mb-1">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <p class="mb-0 d-flex gap-2">
                <a href="electricity-prices" class="btn btn-secondary btn-sm">Elpriser</a>
                <a href="energy-usage" class="btn btn-secondary btn-sm">Timförbrukning</a>
                <a href="monthly-costs" class="btn btn-secondary btn-sm">Nätavgifter</a>
            </p>
        </div>
    </section>

    @{
        var recentErrorsFiltered = RecentErrors
            .Where(e => (DateTime.UtcNow - e.Timestamp).TotalHours < 5)
            .OrderByDescending(e => e.Timestamp)
            .Take(10)
            .ToList();
    }

    @if (recentErrorsFiltered.Count > 0)
    {
        <section class="mt-4">
            <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
                <h4 class="mb-2">Senaste fel</h4>
                <div style="max-height: 300px; overflow-y: auto;">
                    @foreach (var error in recentErrorsFiltered)
                    {
                        <div
                            style="padding: 0.75rem; margin-bottom: 0.5rem; border-left: 3px solid #dc3545; background-color: #f8f9fa; border-radius: 0.25rem;">
                            <div style="display: flex; justify-content: space-between; align-items: start;">
                                <div>
                                    <small class="text-muted d-block">@error.Timestamp.ToString("HH:mm:ss")</small>
                                    <small class="text-secondary d-block"><strong>@error.Source</strong></small>
                                    <small class="d-block">@error.Message</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
</div>

@code {
    private WallboxMeterInfo? CurrentMeterInfo { get; set; }
    private List<ElectricityPrice>? CurrentKvartlista { get; set; }
    private TibberVehicleStatusLimited? CurrentTibberVehicleStatus { get; set; }
    private SystemLoadEventArgs? SystemLoad { get; set; }
    private List<ErrorLogEventArgs> RecentErrors { get; set; } = [];
    private HashSet<string> HighlightedProperties { get; set; } = [];
    private CancellationTokenSource? _highlightCts;

    private Dictionary<string, double?> ShellyTemperatures { get; set; } = new()
    {
        { "sovrum", null },
        { "hall", null },
        { "arbetsrum", null }
    };

    private HashSet<string> HighlightedShellyProperties { get; set; } = [];
    private CancellationTokenSource? _highlightShellyCts;
    private List<WeatherForecast> CurrentWeatherForecast { get; set; } = [];
    private List<ElectricityPrice>? CurrentElectricityPrices { get; set; }
    private IJSObjectReference? _module;
    private bool _isDisposed;
    private CancellationTokenSource? _priceUpdateCts;

    protected override async Task OnInitializedAsync()
    {
        // Hämta senaste meter-information direkt från WallboxWorker
        if (WallboxWorker.MeterInfo is not null)
        {
            CurrentMeterInfo = WallboxWorker.MeterInfo;
        }

        // Hämta senaste fel
        RecentErrors = ErrorLogService.Errors.ToList();

        // Prenumerera på events för real-time uppdateringar
        WallboxWorker.MeterInfoCalculated += OnMeterInfoCalculated;
        ChargeWorker.KvartlistaUpdated += OnKvartlistaUpdated;
        TibberVehicleService.VehicleStatusRetrieved += OnTibberVehicleStatusRetrieved;
        DaikinFacade.StatusChanged += OnDaikinStatusChanged;
        ShellyMqttService.TemperatureChanged += OnShellyTemperatureChanged;
        SmhiWorker.Subscribe(OnWeatherForecastUpdated);
        LinuxWorker.SystemLoadUpdated += OnSystemLoadUpdated;
        ErrorLogService.ErrorLogged += OnErrorLogged;

        // Trigga uppdatering av kvartlista
        CurrentKvartlista = ChargeWorker.GetKvartlista();

        // Ladda elpriser från dagens datum och nästa dag
        await LoadElectricityPricesAsync();

        // Starta uppdatering av elpriser var 5:e minut
        _priceUpdateCts = new CancellationTokenSource();
        _ = UpdatePricesHourlyAsync(_priceUpdateCts.Token);

        // Hämta fordonsstatus med felhantering
        try
        {
            await TibberVehicleService.GetStatusAsync();
        }
        catch (Exception ex)
        {
            // Logga felet så det syns i fellistan, men låt sidan laddas normalt
            Logger.LogError(ex, "Kan inte hämta fordonsstatus från Tibber");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (_isDisposed)
            return;

        if (!firstRender)
            return;

        try
        {
            try
            {
                _module = await Js.InvokeAsync<IJSObjectReference>("import", "./Components/Pages/Home.razor.js");
            }
            catch (JSDisconnectedException)
            {
                return;
            }

            // Rendera graf om priserna redan är laddade
            if (CurrentElectricityPrices?.Count > 0)
            {
                await RenderPriceChartAsync();
            }
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected, ignorera
        }
    }

    private async Task UpdatePricesHourlyAsync(CancellationToken token)
    {
        try
        {
            while (!token.IsCancellationRequested)
            {
                // Vänta i 5 minuter innan nästa uppdatering
                await Task.Delay(TimeSpan.FromMinutes(5), token);

                if (token.IsCancellationRequested)
                    break;

                // Uppdatera priserna
                await LoadElectricityPricesAsync();

                if (CurrentElectricityPrices?.Count > 0)
                {
                    await InvokeAsync(StateHasChanged);

                    // Rendera grafen igen med uppdaterade priser
                    if (_module != null)
                    {
                        await RenderPriceChartAsync();
                    }
                }
            }
        }
        catch (OperationCanceledException)
        {
            // Uppdatering avbruten
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Fel vid uppdatering av elpriser: {ex.Message}");
        }
    }

    private async Task LoadElectricityPricesAsync()
    {
        var today = DateOnly.FromDateTime(DateTime.Now);
        var tomorrow = today.AddDays(1);

        var todayPrices = await ElectricityPriceService.GetPricesForDateAsync(today);
        var tomorrowPrices = await ElectricityPriceService.GetPricesForDateAsync(tomorrow);

        CurrentElectricityPrices = [];
        if (todayPrices?.Count > 0)
            CurrentElectricityPrices.AddRange(todayPrices);
        if (tomorrowPrices?.Count > 0)
            CurrentElectricityPrices.AddRange(tomorrowPrices);
    }

    private async Task RenderPriceChartAsync()
    {
        if (_isDisposed || _module == null || CurrentElectricityPrices == null || CurrentElectricityPrices.Count == 0)
            return;

        var now = DateTime.Now;
        // Avrunda nedåt till början av den aktuella timmen
        var roundedTime = new DateTime(now.Year, now.Month, now.Day, now.Hour, 0, 0);

        // Filtrera priser från aktuell timme och framåt
        var pricesFromNow = CurrentElectricityPrices
            .Where(p => p.TimeStart >= roundedTime)
            .OrderBy(p => p.TimeStart)
            .ToList();

        if (pricesFromNow.Count == 0)
            return;

        var labels = pricesFromNow.Select(p => p.TimeStart.ToString("HH:mm")).ToList();
        var data = pricesFromNow.Select(p => p.SekPerKwh).ToList();

        // Visa aktuell tid med minuter för den lodräta linjen
        var currentTimeForIndicator = now.ToString("HH:mm");

        try
        {
            await _module.InvokeVoidAsync("initializeChart", labels, data, currentTimeForIndicator);
        }
        catch (JSDisconnectedException)
        {
            // Circuit disconnected, ignorera
        }
    }

    private void OnMeterInfoCalculated(object? sender, MeterInfoEventArgs e)
    {
        CurrentMeterInfo = e.MeterInfo;
        InvokeAsync(StateHasChanged);
    }

    private void OnKvartlistaUpdated(object? sender, KvartlistaEventArgs e)
    {
        CurrentKvartlista = e.Kvartlista;
        InvokeAsync(StateHasChanged);
    }

    private void OnTibberVehicleStatusRetrieved(object? sender, TibberVehicleStatusEventArgs e)
    {
        CurrentTibberVehicleStatus = e.Status;
        InvokeAsync(StateHasChanged);
    }

    private void OnDaikinStatusChanged(object? sender, DaikinStatusChangedEventArgs e)
    {
        // Avbryt tidigare highlight-timer
        _highlightCts?.Cancel();
        _highlightCts?.Dispose();
        _highlightCts = new CancellationTokenSource();

        // Lägg till ändringar till highlighted set
        if (e.CurrentTemperatureChanged)
            HighlightedProperties.Add("CurrentTemperature");
        if (e.OutdoorTemperatureChanged)
            HighlightedProperties.Add("OutdoorTemperature");
        if (e.TargetTemperatureChanged)
            HighlightedProperties.Add("TargetTemperature");
        if (e.PowerChanged || e.ModeChanged)
            HighlightedProperties.Add("Mode");
        if (e.CompressorFrequencyChanged)
            HighlightedProperties.Add("CompressorFrequency");

        InvokeAsync(StateHasChanged);

        _ = ClearHighlightAfterDelayAsync(HighlightedProperties, _highlightCts.Token);
    }

    private void OnShellyTemperatureChanged(object? sender, ShellyTemperatureChangedEventArgs e)
    {
        // Avbryt tidigare highlight-timer
        _highlightShellyCts?.Cancel();
        _highlightShellyCts?.Dispose();
        _highlightShellyCts = new CancellationTokenSource();

        // Uppdatera temperatur för motsvarande enhet
        if (ShellyTemperatures.ContainsKey(e.DeviceId))
        {
            ShellyTemperatures[e.DeviceId] = e.TemperatureCelsius;
            HighlightedShellyProperties.Add(e.DeviceId);
        }

        InvokeAsync(StateHasChanged);

        _ = ClearHighlightAfterDelayAsync(HighlightedShellyProperties, _highlightShellyCts.Token);
    }

    private void OnWeatherForecastUpdated(object? sender, WeatherForecastUpdatedEventArgs e)
    {
        CurrentWeatherForecast = e.Forecast;
        InvokeAsync(StateHasChanged);
    }

    private void OnSystemLoadUpdated(object? sender, SystemLoadEventArgs e)
    {
        SystemLoad = e;
        InvokeAsync(StateHasChanged);
    }

    private void OnErrorLogged(object? sender, ErrorLogEventArgs e)
    {
        InvokeAsync(() =>
        {
            RecentErrors.Add(e);

            // Behålla bara senaste 50 fel
            if (RecentErrors.Count > 50)
            {
                RecentErrors.RemoveAt(0);
            }

            StateHasChanged();
        });
    }

    /// <summary>
    /// Rensar highlight-markeringar efter en fördröjning, om inte token avbryts av en nyare uppdatering.
    /// </summary>
    private async Task ClearHighlightAfterDelayAsync(HashSet<string> properties, CancellationToken token)
    {
        try
        {
            await Task.Delay(55000, token);
            properties.Clear();
            await InvokeAsync(StateHasChanged);
        }
        catch (TaskCanceledException)
        {
            // Ny uppdatering inkom innan timeout — ignorera
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        _isDisposed = true;
        WallboxWorker.MeterInfoCalculated -= OnMeterInfoCalculated;
        ChargeWorker.KvartlistaUpdated -= OnKvartlistaUpdated;
        TibberVehicleService.VehicleStatusRetrieved -= OnTibberVehicleStatusRetrieved;
        DaikinFacade.StatusChanged -= OnDaikinStatusChanged;
        ShellyMqttService.TemperatureChanged -= OnShellyTemperatureChanged;
        SmhiWorker.Unsubscribe(OnWeatherForecastUpdated);
        LinuxWorker.SystemLoadUpdated -= OnSystemLoadUpdated;
        ErrorLogService.ErrorLogged -= OnErrorLogged;

        _highlightCts?.Cancel();
        _highlightCts?.Dispose();
        _highlightShellyCts?.Cancel();
        _highlightShellyCts?.Dispose();
        _priceUpdateCts?.Cancel();
        _priceUpdateCts?.Dispose();

        if (_module is not null)
        {
            try
            {
                await _module.DisposeAsync();
            }
            catch (JSDisconnectedException)
            {
                // Circuit redan disconnected, resurser rensas av webbläsaren
            }
        }
    }

}

