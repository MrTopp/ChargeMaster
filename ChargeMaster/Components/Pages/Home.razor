@page "/"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject WallboxWorker WallboxWorker
@inject ChargeWorker ChargeWorker
@using ChargeMaster.Data
@using ChargeMaster.Models
@using ChargeMaster.Workers

<PageTitle>Home</PageTitle>

<h1>ChargeMaster</h1>

<div>
    <p><strong>Aktuell tid:</strong> @CurrentDateTime.ToString("yyyy-MM-dd HH:mm:ss")</p>
</div>

    @if (CurrentMeterInfo is not null)
    {
        <div>
            <h3>Wallbox Meter Information</h3>
            <p><strong>Accumulated Energy:</strong> @((CurrentMeterInfo.AccEnergy / 1000m).ToString("F1")) kWh</p>
            <p><strong>Effekt fas 1:</strong> @CurrentMeterInfo.Phase1CurrentEnergy W</p>
            <p><strong>Effekt fas 2:</strong> @CurrentMeterInfo.Phase2CurrentEnergy W</p>
            <p><strong>Effekt fas 3:</strong> @CurrentMeterInfo.Phase3CurrentEnergy W</p>
            <p><strong>Effekt total:</strong> @CurrentMeterInfo.CurrentEnergy W</p>
        </div>
    }

@if (CurrentKvartlista is not null && CurrentKvartlista.Count > 0)
{
    <div>
        <h3>Laddkvartal (Charging Quarters)</h3>
        <table class="table table-striped">
            <thead>
                <tr>
                    <th>Tid</th>
                    <th>Pris (SEK/kWh)</th>
                    <th>Pris (EUR/kWh)</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var kvart in CurrentKvartlista.OrderBy(x => x.TimeStart))
                {
                    <tr>
                        <td>@kvart.TimeStart.ToString("yyyy-MM-dd HH:mm")</td>
                        <td>@kvart.SekPerKwh.ToString("F2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

<p>
    <a href="electricity-prices">View Electricity Prices</a>
</p>

@code {
    private DateTime CurrentDateTime { get; set; } = DateTime.Now;
    private PeriodicTimer? _periodicTimer;
    private CancellationTokenSource? _cts;
    private WallboxMeterInfo? CurrentMeterInfo { get; set; }
    private List<ElectricityPrice>? CurrentKvartlista { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _periodicTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _cts = new CancellationTokenSource();
        
        WallboxWorker.MeterInfoCalculated += OnMeterInfoCalculated;
        ChargeWorker.KvartlistaUpdated += OnKvartlistaUpdated;
        
        _ = UpdateTimeLoop();
    }

    private void OnMeterInfoCalculated(object? sender, MeterInfoEventArgs e)
    {
        CurrentMeterInfo = e.MeterInfo;
        InvokeAsync(StateHasChanged);
    }

    private void OnKvartlistaUpdated(object? sender, KvartlistaEventArgs e)
    {
        CurrentKvartlista = e.Kvartlista;
        InvokeAsync(StateHasChanged);
    }

    private async Task UpdateTimeLoop()
    {
        while (_periodicTimer is not null && await _periodicTimer.WaitForNextTickAsync(_cts!.Token))
        {
            CurrentDateTime = DateTime.Now;
            await InvokeAsync(StateHasChanged);
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        WallboxWorker.MeterInfoCalculated -= OnMeterInfoCalculated;
        ChargeWorker.KvartlistaUpdated -= OnKvartlistaUpdated;
        
        _cts?.Cancel();
        
        if (_periodicTimer is not null)
        {
            _periodicTimer.Dispose();
        }
        
        _cts?.Dispose();
    }
}
