@page "/"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject WallboxWorker WallboxWorker
@inject ChargeWorker ChargeWorker
@inject VWService VWService
@using ChargeMaster.Services.ElectricityPrice
@using ChargeMaster.Services.Wallbox
@using ChargeMaster.Services.VolksWagen
@using ChargeMaster.Workers

<PageTitle>Charge Master</PageTitle>

<div class="container mt-5 mb-5">
    <section class="mb-5">
        <h3 class="mb-3">Aktuell effekt</h3>

        @if (CurrentMeterInfo is not null)
        {
            <div>
                <table class="table table-striped">
                    <tbody>
                        <tr>
                            <td><strong>Uppdaterad</strong></td>
                            <td>@((LastMeterInfoUpdate).ToString("HH:mm:ss"))</td>
                        </tr>
                        <tr>
                            <td><strong>Effekt fas 1</strong></td>
                            <td>@CurrentMeterInfo.Phase1CurrentEnergy W</td>
                        </tr>
                        <tr>
                            <td><strong>Effekt fas 2</strong></td>
                            <td>@CurrentMeterInfo.Phase2CurrentEnergy W</td>
                        </tr>
                        <tr>
                            <td><strong>Effekt fas 3</strong></td>
                            <td>@CurrentMeterInfo.Phase3CurrentEnergy W</td>
                        </tr>
                        <tr>
                            <td><strong>Effekt total</strong></td>
                            <td>@CurrentMeterInfo.CurrentEnergy W</td>
                        </tr>
                        <tr>
                            <td><strong>Förbrukning denna timme</strong></td>
                            <td>@ChargeWorker.ForbrukningDennaTimme W</td>
                        </tr>
                        <tr class="@(EffektDennaTimmeTotalt > 2500 ? "table-danger" : "")">
                            <td><strong>Uppskattad förbrukning denna timme</strong></td>
                            <td><strong>@(EffektDennaTimmeTotalt) W</strong></td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }
    </section>


    <section class="mb-5">
        <h3 class="mb-3">Bilens laddstatus</h3>

        @if (CurrentVWStatus is not null)
        {
            <div>
                <table class="table table-striped">
                    <tbody>
                        <tr>
                            <td><strong>Batterinivå</strong></td>
                            <td>@((CurrentVWStatus.BatteryLevel ?? 0.0).ToString("F1")) %</td>
                        </tr>
                        <tr>
                            <td><strong>Målnivå för laddning</strong></td>
                            <td>@((CurrentVWStatus.ChargingSettingsTargetLevel ?? 0.0).ToString("F1")) %</td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }
    </section>

    <section class="mb-5">
        <h3 class="mb-3">Kostnader denna månad</h3>
        @if (HighestHourlyUsage is not null)
        {
            <div>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Avgiftstyp</th>
                            <th>Energi (kWh)</th>
                            <th>Timme</th>
                            <th>Pris (SEK)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Effektavgift</strong></td>
                            <td>@((HighestHourlyUsage.EnergyUsageWh / 1000.0).ToString("F2"))</td>
                            <td>@(HighestHourlyUsage.Hour.ToString("yyyy-MM-dd HH:00"))</td>
                            <td>@((HighestHourlyUsage.EnergyUsageWh * 62.5 / 1000).ToString("F2"))</td>
                        </tr>
                        <tr>
                            <td><strong>Högbelastningsavgift</strong></td>
                            <td>@(((HighestDailyHourlyUsage?.EnergyUsageWh ?? 0L) / 1000.0).ToString("F2"))</td>
                            <td>@((HighestDailyHourlyUsage?.Hour)?.ToString("yyyy-MM-dd HH:00") ?? "")</td>
                            <td>@(((HighestDailyHourlyUsage?.EnergyUsageWh ?? 0L) * 50 / 1000.0).ToString("F2"))</td>
                        </tr>
                        <tr>
                            <td><strong>Nätavgift</strong></td>
                            <td>&nbsp;</td>
                            <td>&nbsp;</td>
                            <td>
                                @((3000 / (DateTime.IsLeapYear(DateTime.Now.Year) ? 366 : 365)
                                                            * DateTime.DaysInMonth(DateTime.Now.Year, DateTime.Now.Month)).ToString("F2"))
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Överföring hittills</strong></td>
                            <td>@((MonthlyUsage / 1000.0).ToString("F2"))</td>
                            <td>&nbsp;</td>
                            <td>&nbsp;</td>
                        </tr>
                        <tr>
                            <td><strong>Överföring månad uppskattad</strong></td>
                            <td>@((ForbrukningManadTotalt / 1000.0).ToString("F3"))</td>
                            <td>&nbsp;</td>
                            <td>@((ForbrukningManadTotalt * 0.175 / 1000).ToString("F2"))</td>
                        </tr>
                        <tr>
                            <td><strong>Energiskatt uppskattad</strong></td>
                            <td>@((ForbrukningManadTotalt / 1000.0).ToString("F3"))</td>
                            <td>&nbsp;</td>
                            <td>@((ForbrukningManadTotalt * 0.5488 / 1000).ToString("F2"))</td>
                        </tr>
                        <tr>
                            <td><strong>Summa</strong></td>
                            <td>&nbsp;</td>
                            <td>&nbsp;</td>
                            <td>
                                @(((HighestHourlyUsage.EnergyUsageWh * 62.5 / 1000)
                                                            + (HighestDailyHourlyUsage.EnergyUsageWh * 50 / 1000.0)
                                                            + (3000 / 12.0)
                                                            + (ForbrukningManadTotalt * 0.175 / 1000)
                                                            + (ForbrukningManadTotalt * 0.5488 / 1000)
                                                            ).ToString("F2"))
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p><em>Ingen data tillgänglig</em></p>
        }

    </section>

    <section class="mb-5">
        <h3 class="mb-3">Planerad laddning</h3>

        @if (CurrentKvartlista is not null && CurrentKvartlista.Count > 0)
        {
            <div>
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Tid</th>
                            <th>Pris (SEK/kWh)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kvart in CurrentKvartlista.OrderBy(x => x.TimeStart))
                        {
                            <tr>
                                <td>@kvart.TimeStart.ToString("yyyy-MM-dd HH:mm")</td>
                                <td align="right">@kvart.SekPerKwh.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="alert alert-info">
                Batteriet är fulladdat eller ingen laddning krävs för närvarande.
            </div>
        }
    </section>

    <section class="mb-5">
        <p>
            <a href="electricity-prices" class="btn btn-secondary">Se elpriser</a>
        </p>
    </section>
</div>

@code {
    private PeriodicTimer? _periodicTimer;
    private PeriodicTimer? _hourlyUpdateTimer;
    private CancellationTokenSource? _cts;
    private DateTime LastMeterInfoUpdate { get; set; }
    private WallboxMeterInfo? CurrentMeterInfo { get; set; }
    private List<ElectricityPrice>? CurrentKvartlista { get; set; }
    private HourlyEnergyUsage? HighestHourlyUsage { get; set; }
    private HourlyEnergyUsage? HighestDailyHourlyUsage { get; set; }
    private long MonthlyUsage { get; set; }
    private VWStatusLimitet? CurrentVWStatus { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _periodicTimer = new PeriodicTimer(TimeSpan.FromSeconds(1));
        _cts = new CancellationTokenSource();

        // Hämta senaste meter-information direkt från WallboxWorker
        if (WallboxWorker.MeterInfo is not null)
        {
            CurrentMeterInfo = WallboxWorker.MeterInfo;
            LastMeterInfoUpdate = DateTime.Now;
        }


        // Hämta högsta timförbrukning för denna månad vid sidladdning
        await LoadHighestHourlyUsageAsync();

        // Prenumerera på events för real-time uppdateringar
        WallboxWorker.MeterInfoCalculated += OnMeterInfoCalculated;
        ChargeWorker.KvartlistaUpdated += OnKvartlistaUpdated;
        VWService.VWStatusRetrieved += OnVWStatusRetrieved;

        // Trigga uppdatering av kvartlista
        CurrentKvartlista = ChargeWorker.GetKvartlista();

        _ = VWService.GetStatus();

        _ = UpdateHourlyEnergyLoop();
    }

    private long EffektDennaTimmeTotalt
    {
        get
        {
            if (DateTime.Now.Minute + DateTime.Now.Second == 0)
            {
                return 0; // Undvik division med noll
            }
            return ChargeWorker.ForbrukningDennaTimme * 3600 / (DateTime.Now.Minute * 60 + DateTime.Now.Second);
        }
    }

    private long ForbrukningManadTotalt => MonthlyUsage * DateTime.DaysInMonth(DateTime.Now.Year, DateTime.Now.Month) / DateTime.Now.Day;

    private void OnMeterInfoCalculated(object? sender, MeterInfoEventArgs e)
    {
        CurrentMeterInfo = e.MeterInfo;
        LastMeterInfoUpdate = e.Timestamp;
        InvokeAsync(StateHasChanged);
    }

    private void OnKvartlistaUpdated(object? sender, KvartlistaEventArgs e)
    {
        CurrentKvartlista = e.Kvartlista;
        InvokeAsync(StateHasChanged);
    }

    private void OnVWStatusRetrieved(object? sender, VWStatusEventArgs e)
    {
        CurrentVWStatus = e.VWStatusLimitet;
        InvokeAsync(StateHasChanged);
    }

    private async Task LoadHighestHourlyUsageAsync()
    {
        HighestHourlyUsage = await WallboxWorker.GetHighestHourlyEnergyUsageAsync(DateTime.Now);
        HighestDailyHourlyUsage = await WallboxWorker.GetHighestHourlyEnergyUsageDaytimeAsync(DateTime.Now);
        MonthlyUsage = await WallboxWorker.GetMonthlyEnergyUsageAsync(DateTime.Now);
    }

    private async Task UpdateHourlyEnergyLoop()
    {
        // Uppdatera vid nästa timgräns
        var now = DateTime.Now;
        var nextHour = now.AddHours(1).Date.AddHours(now.AddHours(1).Hour);
        var timeUntilNextHour = nextHour - now;

        await Task.Delay(timeUntilNextHour, _cts!.Token);

        // Skapa en timer som uppdaterar varje timme efter det
        _hourlyUpdateTimer = new PeriodicTimer(TimeSpan.FromHours(1));

        while (_hourlyUpdateTimer is not null && await _hourlyUpdateTimer.WaitForNextTickAsync(_cts!.Token))
        {
            await LoadHighestHourlyUsageAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        WallboxWorker.MeterInfoCalculated -= OnMeterInfoCalculated;
        ChargeWorker.KvartlistaUpdated -= OnKvartlistaUpdated;
        VWService.VWStatusRetrieved -= OnVWStatusRetrieved;

        if (_cts != null)
        {
            await _cts.CancelAsync();
        }

        if (_periodicTimer is not null)
        {
            _periodicTimer.Dispose();
        }

        if (_hourlyUpdateTimer is not null)
        {
            _hourlyUpdateTimer.Dispose();
        }

        _cts?.Dispose();
    }
}

