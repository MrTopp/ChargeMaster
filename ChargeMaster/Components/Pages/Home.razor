@page "/index"
@page "/"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject WallboxWorker WallboxWorker
@inject ChargeWorker ChargeWorker
@inject VWService VWService
@inject DaikinFacade DaikinFacade
@inject ShellyMqttService ShellyMqttService
@inject SmhiWorker SmhiWorker
@inject LinuxWorker LinuxWorker
@inject ErrorLogService ErrorLogService
@using ChargeMaster.Data
@using ChargeMaster.Services.Wallbox
@using ChargeMaster.Services.VolksWagen
@using ChargeMaster.Services.Daikin
@using ChargeMaster.Services.Shelly
@using ChargeMaster.Services.SMHI
@using ChargeMaster.Services.ErrorLog
@using ChargeMaster.Workers

<PageTitle>Charge Master</PageTitle>

<div class="container-md mb-3 px-2 px-sm-3 px-md-4" style="min-height: 100vh; display: flex; flex-direction: column;">
    <div style="flex: 0.5 1 0; max-height: 3rem; min-height: 8px;"></div>

    <section class="mb-3">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-2">Aktuell effekt</h4>

            @if (CurrentMeterInfo is not null)
            {
                <div class="row g-2 mb-3">
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                        <small class="text-muted">Fas 1:</small><br>
                        <strong>@CurrentMeterInfo.Phase1CurrentEnergy W</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                        <small class="text-muted">Fas 2:</small><br>
                        <strong>@CurrentMeterInfo.Phase2CurrentEnergy W</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                        <small class="text-muted">Fas 3:</small><br>
                        <strong>@CurrentMeterInfo.Phase3CurrentEnergy W</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                        <small class="text-muted">Total:</small><br>
                        <strong>@CurrentMeterInfo.CurrentEnergy W</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                        <small class="text-muted">Denna timme:</small><br>
                        <strong>@CurrentMeterInfo.EffektTimmeNuFormatted Wh</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(CurrentMeterInfo.EffektTimmeTotal > 2500 ? "background-color: #f8d7da;" : "")">
                        <small class="text-muted">Uppskattad timme:</small><br>
                        <strong>@CurrentMeterInfo.EffektTimmeTotalFormatted Wh</strong>
                    </div>
                </div>
            }
        </div>
    </section>

    <section class="mb-3">
        <div class="row g-3" style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <div class="col-md-5">
                <h4 class="mb-2">Temperatur (Shelly)</h4>
                <div class="row g-2">
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedShellyProperties.Contains("sovrum") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Sovrum:</small><br>
                        <strong>@ShellyTemperatures["sovrum"]?.ToString("F1")°</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedShellyProperties.Contains("hall") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Hall:</small><br>
                        <strong>@ShellyTemperatures["hall"]?.ToString("F1")°</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedShellyProperties.Contains("arbetsrum") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Arbetsrum:</small><br>
                        <strong>@ShellyTemperatures["arbetsrum"]?.ToString("F1")°</strong>
                    </div>
                </div>
            </div>
            <div class="col-md-7">
                <h4 class="mb-2">Värmepump (Daikin)</h4>
                <div class="row g-2">
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("CurrentTemperature") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Inne:</small><br>
                        <strong>@DaikinFacade.CurrentTemperature?.ToString("F1")°</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("OutdoorTemperature") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Ute:</small><br>
                        <strong>@DaikinFacade.OutdoorTemperature?.ToString("F1")°</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("TargetTemperature") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Mål:</small><br>
                        <strong>@DaikinFacade.TargetTemperature?.ToString("F1")°</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("Mode") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Läge:</small><br>
                        <strong>@(DaikinFacade.IsOn ? DaikinFacade.Mode.ToString() : "Av")</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("CompressorFrequency") ? "background-color: #cfe2ff;" : "")">
                        <small class="text-muted">Kompr.:</small><br>
                        <strong>@(DaikinFacade.CompressorFrequency ?? 0)</strong>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-3">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-2">Väderprognos (SMHI)</h4>

            @if (CurrentWeatherForecast.Count > 0)
            {
                <div class="row g-2 mb-3">
                    @foreach (var forecast in CurrentWeatherForecast.Take(14))
                    {
                        <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; text-align: center;">
                            <small class="text-muted">@forecast.Time.ToString("H:mm")</small><br>
                            <strong>@forecast.Temperature.ToString("F1")°</strong><br>
                            <span style="font-size: 1.5rem; line-height: 1; display: block; margin-top: 0.25rem;">@forecast.WeatherEmoji</span>
                        </div>
                    }
                </div>
            }
            else
            {
                <p class="text-muted mb-0"><em>Ingen data tillgänglig</em></p>
            }
        </div>
    </section>

    <section class="mb-3">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-2">Bilens laddstatus</h4>

            @if (CurrentVWStatus is not null)
            {
                <div class="row g-2">
                    <div class="col-auto">
                        <small class="text-muted">Batterinivå:</small><br>
                        <strong>@((CurrentVWStatus.BatteryLevel ?? 0.0).ToString("F0")) %</strong>
                    </div>
                    <div class="col-auto">
                        <small class="text-muted">Målnivå:</small><br>
                        <strong>@((CurrentVWStatus.ChargingSettingsTargetLevel ?? 0.0).ToString("F0")) %</strong>
                    </div>
                </div>
            }
        </div>
    </section>

@if (SystemLoad is not null)
    {
        <section class="mb-3">
            <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
                <h4 class="mb-2">Systemlast (Linux)</h4>

                <div class="row g-2">
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                        <small class="text-muted">1 minut:</small><br>
                        <strong>@SystemLoad.Load1.ToString("F2")</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                        <small class="text-muted">5 minuter:</small><br>
                        <strong>@SystemLoad.Load5.ToString("F2")</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                        <small class="text-muted">15 minuter:</small><br>
                        <strong>@SystemLoad.Load15.ToString("F2")</strong>
                    </div>
                    <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem;">
                        <small class="text-muted">Processer:</small><br>
                        <strong>@SystemLoad.RunningProcesses/@SystemLoad.TotalProcesses</strong>
                    </div>
                </div>
            </div>
        </section>
    }

    <section class="mb-3">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-2">Planerad laddning</h4>

            @if (CurrentKvartlista is not null && CurrentKvartlista.Count > 0)
            {
                <div style="display: grid; grid-template-columns: repeat(8, 1fr); gap: 0.5rem;" class="mb-3">
                    @foreach (var kvart in CurrentKvartlista.OrderBy(x => x.TimeStart))
                    {
                        <div style="padding: 0.5rem; border-radius: 0.25rem; text-align: center; background-color: #f8f9fa;">
                            <small class="text-muted">@kvart.TimeStart.ToString("MM-dd HH:mm")</small><br>
                            <strong>@kvart.SekPerKwh.ToString("F2") kr</strong>
                        </div>
                    }
                </div>
            }
            else
            {
                <div class="alert alert-info mb-0" role="alert">
                    Batteriet är fulladdat eller ingen laddning krävs för närvarande.
                </div>
            }
        </div>
    </section>

    <section>
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
        <p class="mb-0 d-flex gap-2">
            <a href="electricity-prices" class="btn btn-secondary btn-sm">Elpriser</a>
            <a href="energy-usage" class="btn btn-secondary btn-sm">Timförbrukning</a>
            <a href="monthly-costs" class="btn btn-secondary btn-sm">Nätavgifter</a>
        </p>
        </div>
    </section>

    @if (RecentErrors.Count > 0)
    {
        <section class="mt-4">
            <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
                <h4 class="mb-2">Senaste fel</h4>
                <div style="max-height: 300px; overflow-y: auto;">
                    @foreach (var error in RecentErrors.OrderByDescending(e => e.Timestamp).Take(10))
                    {
                        <div style="padding: 0.75rem; margin-bottom: 0.5rem; border-left: 3px solid #dc3545; background-color: #f8f9fa; border-radius: 0.25rem;">
                            <div style="display: flex; justify-content: space-between; align-items: start;">
                                <div>
                                    <small class="text-muted d-block">@error.Timestamp.ToString("HH:mm:ss")</small>
                                    <small class="text-secondary d-block"><strong>@error.Source</strong></small>
                                    <small class="d-block">@error.Message</small>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
</div>

@code {
    private CancellationTokenSource? _cts;
    private WallboxMeterInfo? CurrentMeterInfo { get; set; }
    private List<ElectricityPrice>? CurrentKvartlista { get; set; }
    private VWStatusLimitet? CurrentVWStatus { get; set; }
    private SystemLoadEventArgs? SystemLoad { get; set; }
    private List<ErrorLogEventArgs> RecentErrors { get; set; } = [];
    private HashSet<string> HighlightedProperties { get; set; } = [];
    private CancellationTokenSource? _highlightCts;
    private Dictionary<string, double?> ShellyTemperatures { get; set; } = new()
    {
        { "sovrum", null },
        { "hall", null },
        { "arbetsrum", null }
    };
    private HashSet<string> HighlightedShellyProperties { get; set; } = [];
    private CancellationTokenSource? _highlightShellyCts;
    private List<WeatherForecast> CurrentWeatherForecast { get; set; } = [];

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();

        // Hämta senaste meter-information direkt från WallboxWorker
        if (WallboxWorker.MeterInfo is not null)
        {
            CurrentMeterInfo = WallboxWorker.MeterInfo;
        }

        // Hämta senaste fel
        RecentErrors = ErrorLogService.Errors.ToList();

        // Prenumerera på events för real-time uppdateringar
        WallboxWorker.MeterInfoCalculated += OnMeterInfoCalculated;
        ChargeWorker.KvartlistaUpdated += OnKvartlistaUpdated;
        VWService.VWStatusRetrieved += OnVWStatusRetrieved;
        DaikinFacade.StatusChanged += OnDaikinStatusChanged;
        ShellyMqttService.TemperatureChanged += OnShellyTemperatureChanged;
        SmhiWorker.Subscribe(OnWeatherForecastUpdated);
        LinuxWorker.SystemLoadUpdated += OnSystemLoadUpdated;
        ErrorLogService.ErrorLogged += OnErrorLogged;

        // Trigga uppdatering av kvartlista
        CurrentKvartlista = ChargeWorker.GetKvartlista();

        _ = VWService.GetStatus();

        // Initialisera Daikin-facade
        await DaikinFacade.InitializeAsync();
    }

    private void OnMeterInfoCalculated(object? sender, MeterInfoEventArgs e)
    {
        CurrentMeterInfo = e.MeterInfo;
        InvokeAsync(StateHasChanged);
    }

    private void OnKvartlistaUpdated(object? sender, KvartlistaEventArgs e)
    {
        CurrentKvartlista = e.Kvartlista;
        InvokeAsync(StateHasChanged);
    }

    private void OnVWStatusRetrieved(object? sender, VWStatusEventArgs e)
    {
        CurrentVWStatus = e.VWStatusLimitet;
        InvokeAsync(StateHasChanged);
    }

    private void OnDaikinStatusChanged(object? sender, DaikinStatusChangedEventArgs e)
    {
        // Avbryt tidigare highlight-timer
        _highlightCts?.Cancel();
        _highlightCts = new CancellationTokenSource();

        // Lägg till ändringar till highlighted set
        if (e.CurrentTemperatureChanged)
            HighlightedProperties.Add("CurrentTemperature");
        if (e.OutdoorTemperatureChanged)
            HighlightedProperties.Add("OutdoorTemperature");
        if (e.TargetTemperatureChanged)
            HighlightedProperties.Add("TargetTemperature");
        if (e.PowerChanged || e.ModeChanged)
            HighlightedProperties.Add("Mode");
        if (e.CompressorFrequencyChanged)
            HighlightedProperties.Add("CompressorFrequency");

        InvokeAsync(StateHasChanged);

        // Ta bort highlight efter 55 sekunder
        _ = Task.Delay(55000, _highlightCts.Token).ContinueWith(async _ =>
        {
            if (!_highlightCts.Token.IsCancellationRequested)
            {
                HighlightedProperties.Clear();
                await InvokeAsync(StateHasChanged);
            }
        });
    }

    private void OnShellyTemperatureChanged(object? sender, ShellyTemperatureChangedEventArgs e)
    {
        // Avbryt tidigare highlight-timer
        if (_highlightShellyCts is { IsCancellationRequested: false })
        {
            _highlightShellyCts.Cancel();
        }
        _highlightShellyCts = new CancellationTokenSource();

        // Uppdatera temperatur för motsvarande enhet
        if (ShellyTemperatures.ContainsKey(e.DeviceId))
        {
            ShellyTemperatures[e.DeviceId] = e.TemperatureCelsius;
            HighlightedShellyProperties.Add(e.DeviceId);
        }

        InvokeAsync(StateHasChanged);

        // Ta bort highlight efter 55 sekunder
        _ = Task.Delay(55000, _highlightShellyCts.Token).ContinueWith(async _ =>
        {
            if (!_highlightShellyCts.Token.IsCancellationRequested)
            {
                HighlightedShellyProperties.Clear();
                await InvokeAsync(StateHasChanged);
            }
        });
    }

    private void OnWeatherForecastUpdated(object? sender, WeatherForecastUpdatedEventArgs e)
    {
        CurrentWeatherForecast = e.Forecast;
        InvokeAsync(StateHasChanged);
    }

    private void OnSystemLoadUpdated(object? sender, SystemLoadEventArgs e)
    {
        SystemLoad = e;
        InvokeAsync(StateHasChanged);
    }

    private void OnErrorLogged(object? sender, ErrorLogEventArgs e)
    {
        RecentErrors.Add(e);

        // Behålla bara senaste 50 fel
        if (RecentErrors.Count > 50)
        {
            RecentErrors.RemoveAt(0);
        }

        InvokeAsync(StateHasChanged);
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        WallboxWorker.MeterInfoCalculated -= OnMeterInfoCalculated;
        ChargeWorker.KvartlistaUpdated -= OnKvartlistaUpdated;
        VWService.VWStatusRetrieved -= OnVWStatusRetrieved;
        DaikinFacade.StatusChanged -= OnDaikinStatusChanged;
        ShellyMqttService.TemperatureChanged -= OnShellyTemperatureChanged;
        SmhiWorker.Unsubscribe(OnWeatherForecastUpdated);
        LinuxWorker.SystemLoadUpdated -= OnSystemLoadUpdated;
        ErrorLogService.ErrorLogged -= OnErrorLogged;

        _highlightCts?.Cancel();
        _highlightCts?.Dispose();
        _highlightShellyCts?.Cancel();
        _highlightShellyCts?.Dispose();

        if (_cts != null)
        {
            await _cts.CancelAsync();
        }

        _cts?.Dispose();
    }
}

