@page "/"
@rendermode InteractiveServer
@implements IAsyncDisposable
@inject WallboxWorker WallboxWorker
@inject ChargeWorker ChargeWorker
@inject VWService VWService
@inject DaikinFacade DaikinFacade
@inject ShellyMqttService ShellyMqttService
@using ChargeMaster.Services.ElectricityPrice
@using ChargeMaster.Services.Wallbox
@using ChargeMaster.Services.VolksWagen
@using ChargeMaster.Services.Daikin
@using ChargeMaster.Services.Shelly
@using ChargeMaster.Workers

<PageTitle>Charge Master</PageTitle>

<div class="container-md mb-3 px-2 px-sm-3 px-md-4" style="min-height: 100vh; display: flex; flex-direction: column;">
    <div style="flex: 0.5 1 0; max-height: 3rem; min-height: 8px;"></div>

    <section class="mb-3">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-2">Aktuell effekt</h4>

            @if (CurrentMeterInfo is not null)
            {
                <div>
                    <table class="table table-striped table-sm">
                        <tbody>
@*                         <tr>
                            <td><strong>Uppdaterad</strong></td>
                            <td class="text-end">@((LastMeterInfoUpdate).ToString("HH:mm:ss"))</td>
                        </tr>
 *@                        <tr>
                            <td><strong>Effekt fas 1</strong></td>
                            <td class="text-end">@CurrentMeterInfo.Phase1CurrentEnergy W</td>
                        </tr>
                        <tr>
                            <td><strong>Effekt fas 2</strong></td>
                            <td class="text-end">@CurrentMeterInfo.Phase2CurrentEnergy W</td>
                        </tr>
                        <tr>
                            <td><strong>Effekt fas 3</strong></td>
                            <td class="text-end">@CurrentMeterInfo.Phase3CurrentEnergy W</td>
                        </tr>
                        <tr>
                            <td><strong>Effekt total</strong></td>
                            <td class="text-end">@CurrentMeterInfo.CurrentEnergy W</td>
                        </tr>
                        <tr>
                            <td><strong>Förbrukning denna timme</strong></td>
                            <td class="text-end">@(CurrentMeterInfo.EffektTimmeNuFormatted) W</td>
                        </tr>
                        <tr class="@(CurrentMeterInfo.EffektTimmeTotal > 2500 ? "table-danger" : "")">
                            <td><strong>Uppskattad förbrukning denna timme</strong></td>
                            <td class="text-end">@(CurrentMeterInfo.EffektTimmeTotalFormatted) W</td>
                        </tr>
                        </tbody>
                </table>
                </div>
            }
        </div>
    </section>

    <section class="mb-3">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-2">Värmepump (Daikin)</h4>

            <div class="row g-2 mb-3">
                <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("CurrentTemperature") ? "background-color: #cfe2ff;" : "")">
                    <small class="text-muted">Innetemperatur:</small><br>
                    <strong>@DaikinFacade.CurrentTemperature?.ToString("F1") °C</strong>
                </div>
                <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("OutdoorTemperature") ? "background-color: #cfe2ff;" : "")">
                    <small class="text-muted">Utetemperatur:</small><br>
                    <strong>@DaikinFacade.OutdoorTemperature?.ToString("F1") °C</strong>
                </div>
                <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("TargetTemperature") ? "background-color: #cfe2ff;" : "")">
                    <small class="text-muted">Måltemperatur:</small><br>
                    <strong>@DaikinFacade.TargetTemperature?.ToString("F1") °C</strong>
                </div>
                <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("Mode") ? "background-color: #cfe2ff;" : "")">
                    <small class="text-muted">Läge:</small><br>
                    <strong>@DaikinFacade.Mode</strong>
                </div>
                <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedProperties.Contains("Power") ? "background-color: #cfe2ff;" : "")">
                    <small class="text-muted">Status:</small><br>
                    <strong>@(DaikinFacade.IsOn ? "PÅ" : "AV")</strong>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-3">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-2">Temperatur (Shelly)</h4>

            <div class="row g-2 mb-3">
                <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedShellyProperties.Contains("sovrum") ? "background-color: #cfe2ff;" : "")">
                    <small class="text-muted">Sovrum:</small><br>
                    <strong>@ShellyTemperatures["sovrum"]?.ToString("F1") °C</strong>
                </div>
                <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedShellyProperties.Contains("hall") ? "background-color: #cfe2ff;" : "")">
                    <small class="text-muted">Hall:</small><br>
                    <strong>@ShellyTemperatures["hall"]?.ToString("F1") °C</strong>
                </div>
                <div class="col-auto" style="padding: 0.5rem; border-radius: 0.25rem; @(HighlightedShellyProperties.Contains("arbetsrum") ? "background-color: #cfe2ff;" : "")">
                    <small class="text-muted">Arbetsrum:</small><br>
                    <strong>@ShellyTemperatures["arbetsrum"]?.ToString("F1") °C</strong>
                </div>
            </div>
        </div>
    </section>

    <section class="mb-3">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-2">Bilens laddstatus</h4>

            @if (CurrentVWStatus is not null)
            {
                <div class="row g-2">
                    <div class="col-auto">
                        <small class="text-muted">Batterinivå:</small><br>
                        <strong>@((CurrentVWStatus.BatteryLevel ?? 0.0).ToString("F0")) %</strong>
                    </div>
                    <div class="col-auto">
                        <small class="text-muted">Målnivå:</small><br>
                        <strong>@((CurrentVWStatus.ChargingSettingsTargetLevel ?? 0.0).ToString("F0")) %</strong>
                    </div>
                </div>
            }
        </div>
    </section>

            <section class="mb-3">
                <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
                    <h4 class="mb-2">Kostnader denna månad</h4>
                    @if (HighestHourlyUsage is not null)
                    {
                        <div class="table-responsive">
                <table class="table table-striped table-sm">
                    <thead>
                        <tr>
                            <th>Avgiftstyp</th>
                            <th class="text-end">Energi (kWh)</th>
                            <th>Timme</th>
                            <th class="text-end">Pris (SEK)</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td><strong>Effektavgift</strong></td>
                            <td class="text-end">@((HighestHourlyUsage.EnergyUsageWh / 1000.0).ToString("F2"))</td>
                            <td>@(HighestHourlyUsage.Hour.ToString("yyyy-MM-dd HH:00"))</td>
                            <td class="text-end">@((HighestHourlyUsage.EnergyUsageWh * 62.5 / 1000).ToString("F2"))</td>
                        </tr>
                        <tr>
                            <td><strong>Högbelastningsavgift</strong></td>
                            <td class="text-end">@(((HighestDailyHourlyUsage?.EnergyUsageWh ?? 0L) / 1000.0).ToString("F2"))</td>
                            <td>@((HighestDailyHourlyUsage?.Hour)?.ToString("yyyy-MM-dd HH:00") ?? "")</td>
                            <td class="text-end">@(((HighestDailyHourlyUsage?.EnergyUsageWh ?? 0L) * 50 / 1000.0).ToString("F2"))</td>
                        </tr>
                        <tr>
                            <td><strong>Nätavgift</strong></td>
                            <td>&nbsp;</td>
                            <td>&nbsp;</td>
                            <td class="text-end">
                                @((3000 / (DateTime.IsLeapYear(DateTime.Now.Year) ? 366 : 365)
                                                            * DateTime.DaysInMonth(DateTime.Now.Year, DateTime.Now.Month)).ToString("F2"))
                            </td>
                        </tr>
                        <tr>
                            <td><strong>Överföring hittills</strong></td>
                            <td class="text-end">@((MonthlyUsage / 1000.0).ToString("F2"))</td>
                            <td>&nbsp;</td>
                            <td>&nbsp;</td>
                        </tr>
                        <tr>
                            <td><strong>Överföring månad uppskattad</strong></td>
                            <td class="text-end">@((ForbrukningManadTotalt / 1000.0).ToString("F3"))</td>
                            <td>&nbsp;</td>
                            <td class="text-end">@((ForbrukningManadTotalt * 0.175 / 1000).ToString("F2"))</td>
                        </tr>
                        <tr>
                            <td><strong>Energiskatt uppskattad</strong></td>
                            <td class="text-end">@((ForbrukningManadTotalt / 1000.0).ToString("F3"))</td>
                            <td>&nbsp;</td>
                            <td class="text-end">@((ForbrukningManadTotalt * 0.5488 / 1000).ToString("F2"))</td>
                        </tr>
                        <tr>
                            <td><strong>Summa</strong></td>
                            <td>&nbsp;</td>
                            <td>&nbsp;</td>
                            <td class="text-end">
                                @(((HighestHourlyUsage.EnergyUsageWh * 62.5 / 1000)
                                                            + (HighestDailyHourlyUsage.EnergyUsageWh * 50 / 1000.0)
                                                            + (3000 / 12.0)
                                                            + (ForbrukningManadTotalt * 0.175 / 1000)
                                                            + (ForbrukningManadTotalt * 0.5488 / 1000)
                                                            ).ToString("F2"))
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
            }
            else
            {
                <p class="text-muted mb-0"><em>Ingen data tillgänglig</em></p>
            }
        </div>
    </section>

    <section class="mb-3">
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
            <h4 class="mb-2">Planerad laddning</h4>

            @if (CurrentKvartlista is not null && CurrentKvartlista.Count > 0)
            {
                <div class="table-responsive">
                <table class="table table-striped table-sm">
                    <thead>
                        <tr>
                            <th>Tid</th>
                            <th class="text-end">Pris (SEK/kWh)</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var kvart in CurrentKvartlista.OrderBy(x => x.TimeStart))
                        {
                            <tr>
                                <td>@kvart.TimeStart.ToString("yyyy-MM-dd HH:mm")</td>
                                <td class="text-end">@kvart.SekPerKwh.ToString("F2")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            }
            else
            {
                <div class="alert alert-info mb-0" role="alert">
                    Batteriet är fulladdat eller ingen laddning krävs för närvarande.
                </div>
            }
        </div>
    </section>

    <section>
        <div style="max-width: 720px; margin-left: auto; margin-right: auto;">
        <p class="mb-0 d-flex gap-2">
            <a href="electricity-prices" class="btn btn-secondary btn-sm">Se elpriser</a>
            <a href="energy-usage" class="btn btn-secondary btn-sm">Timförbrukning</a>
        </p>
        </div>
    </section>
</div>

@code {
    private PeriodicTimer? _hourlyUpdateTimer;
    private CancellationTokenSource? _cts;
    private DateTime LastMeterInfoUpdate { get; set; }
    private WallboxMeterInfo? CurrentMeterInfo { get; set; }
    private List<ElectricityPrice>? CurrentKvartlista { get; set; }
    private HourlyEnergyUsage? HighestHourlyUsage { get; set; }
    private HourlyEnergyUsage? HighestDailyHourlyUsage { get; set; }
    private long MonthlyUsage { get; set; }
    private VWStatusLimitet? CurrentVWStatus { get; set; }
    private HashSet<string> HighlightedProperties { get; set; } = [];
    private CancellationTokenSource? _highlightCts;
    private Dictionary<string, double?> ShellyTemperatures { get; set; } = new()
    {
        { "sovrum", null },
        { "hall", null },
        { "arbetsrum", null }
    };
    private HashSet<string> HighlightedShellyProperties { get; set; } = [];
    private CancellationTokenSource? _highlightShellyCts;

    protected override async Task OnInitializedAsync()
    {
        _cts = new CancellationTokenSource();

        // Hämta senaste meter-information direkt från WallboxWorker
        if (WallboxWorker.MeterInfo is not null)
        {
            CurrentMeterInfo = WallboxWorker.MeterInfo;
            LastMeterInfoUpdate = DateTime.Now;
        }


        // Hämta högsta timförbrukning för denna månad vid sidladdning
        await LoadHighestHourlyUsageAsync();

        // Prenumerera på events för real-time uppdateringar
        WallboxWorker.MeterInfoCalculated += OnMeterInfoCalculated;
        ChargeWorker.KvartlistaUpdated += OnKvartlistaUpdated;
        VWService.VWStatusRetrieved += OnVWStatusRetrieved;
        DaikinFacade.StatusChanged += OnDaikinStatusChanged;
        ShellyMqttService.TemperatureChanged += OnShellyTemperatureChanged;

        // Trigga uppdatering av kvartlista
        CurrentKvartlista = ChargeWorker.GetKvartlista();

        _ = VWService.GetStatus();

        // Initialisera Daikin-facade
        await DaikinFacade.InitializeAsync();

        _ = UpdateHourlyEnergyLoop();
    }

    private long ForbrukningManadTotalt => MonthlyUsage * DateTime.DaysInMonth(DateTime.Now.Year, DateTime.Now.Month) / DateTime.Now.Day;

    private void OnMeterInfoCalculated(object? sender, MeterInfoEventArgs e)
    {
        CurrentMeterInfo = e.MeterInfo;
        LastMeterInfoUpdate = e.Timestamp;
        InvokeAsync(StateHasChanged);
    }

    private void OnKvartlistaUpdated(object? sender, KvartlistaEventArgs e)
    {
        CurrentKvartlista = e.Kvartlista;
        InvokeAsync(StateHasChanged);
    }

    private void OnVWStatusRetrieved(object? sender, VWStatusEventArgs e)
    {
        CurrentVWStatus = e.VWStatusLimitet;
        InvokeAsync(StateHasChanged);
    }

    private void OnDaikinStatusChanged(object? sender, DaikinStatusChangedEventArgs e)
    {
        // Avbryt tidigare highlight-timer
        _highlightCts?.Cancel();
        _highlightCts = new CancellationTokenSource();

        // Lägg till ändringar till highlighted set
        if (e.CurrentTemperatureChanged)
            HighlightedProperties.Add("CurrentTemperature");
        if (e.OutdoorTemperatureChanged)
            HighlightedProperties.Add("OutdoorTemperature");
        if (e.TargetTemperatureChanged)
            HighlightedProperties.Add("TargetTemperature");
        if (e.PowerChanged)
            HighlightedProperties.Add("Power");
        if (e.ModeChanged)
            HighlightedProperties.Add("Mode");

        InvokeAsync(StateHasChanged);

        // Ta bort highlight efter 55 sekunder
        _ = Task.Delay(55000, _highlightCts.Token).ContinueWith(async _ =>
        {
            if (!_highlightCts.Token.IsCancellationRequested)
            {
                HighlightedProperties.Clear();
                await InvokeAsync(StateHasChanged);
            }
        });
    }

    private void OnShellyTemperatureChanged(object? sender, ShellyTemperatureChangedEventArgs e)
    {
        // Avbryt tidigare highlight-timer
        _highlightShellyCts?.Cancel();
        _highlightShellyCts = new CancellationTokenSource();

        // Uppdatera temperatur för motsvarande enhet
        if (ShellyTemperatures.ContainsKey(e.DeviceId))
        {
            ShellyTemperatures[e.DeviceId] = e.TemperatureCelsius;
            HighlightedShellyProperties.Add(e.DeviceId);
        }

        InvokeAsync(StateHasChanged);

        // Ta bort highlight efter 55 sekunder
        _ = Task.Delay(55000, _highlightShellyCts.Token).ContinueWith(async _ =>
        {
            if (!_highlightShellyCts.Token.IsCancellationRequested)
            {
                HighlightedShellyProperties.Clear();
                await InvokeAsync(StateHasChanged);
            }
        });
    }

    private async Task LoadHighestHourlyUsageAsync()
    {
        HighestHourlyUsage = await WallboxWorker.GetHighestHourlyEnergyUsageAsync(DateTime.Now);
        HighestDailyHourlyUsage = await WallboxWorker.GetHighestHourlyEnergyUsageDaytimeAsync(DateTime.Now);
        MonthlyUsage = await WallboxWorker.GetMonthlyEnergyUsageAsync(DateTime.Now);
    }

    private async Task UpdateHourlyEnergyLoop()
    {
        // Uppdatera vid nästa timgräns
        var now = DateTime.Now;
        var nextHour = now.AddHours(1).Date.AddHours(now.AddHours(1).Hour);
        var timeUntilNextHour = nextHour - now;

        await Task.Delay(timeUntilNextHour, _cts!.Token);

        // Skapa en timer som uppdaterar varje timme efter det
        _hourlyUpdateTimer = new PeriodicTimer(TimeSpan.FromHours(1));

        while (_hourlyUpdateTimer is not null && await _hourlyUpdateTimer.WaitForNextTickAsync(_cts!.Token))
        {
            await LoadHighestHourlyUsageAsync();
            await InvokeAsync(StateHasChanged);
        }
    }

    async ValueTask IAsyncDisposable.DisposeAsync()
    {
        WallboxWorker.MeterInfoCalculated -= OnMeterInfoCalculated;
        ChargeWorker.KvartlistaUpdated -= OnKvartlistaUpdated;
        VWService.VWStatusRetrieved -= OnVWStatusRetrieved;
        DaikinFacade.StatusChanged -= OnDaikinStatusChanged;
        ShellyMqttService.TemperatureChanged -= OnShellyTemperatureChanged;

        _highlightCts?.Cancel();
        _highlightCts?.Dispose();
        _highlightShellyCts?.Cancel();
        _highlightShellyCts?.Dispose();

        if (_cts != null)
        {
            await _cts.CancelAsync();
        }

        if (_hourlyUpdateTimer is not null)
        {
            _hourlyUpdateTimer.Dispose();
        }

        _cts?.Dispose();
    }
}

